{% extends "layout.njk" %}

{% block styles %}
	<!-- build:css styles/addresses.css -->
	<link rel="stylesheet" href="styles/addresses.css">
	<!-- endbuild -->

	<!-- Tempus Dominus Styles -->
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@eonasdan/tempus-dominus@6.7.11/dist/css/tempus-dominus.min.css" crossorigin="anonymous">
{% endblock %}

{% block navigation %}
	{% import 'macros/nav-macro.njk' as nav %}
	{{nav.active('')}}
{% endblock %}

{% block content %}
	<div class="col-md-12">
		<div class="row w-100">
			<div class="col-md-12 mb-3 mb-md-4">
				<h2 class="m-0">Address</h2>
			</div>
		</div>
		<div id="summaryOk" class="mb-3" style="display: none;">
			<div class="row w-100 div-cell-dark border-bottom-flat p-2 p-lg-3 address-identity-row">
				<div class="col pe-0 ps-0">
					<div class="address-identity-line">
						<a title="Copy" onclick="copyWalletAddress(event)" href="Copy to clipboard!" id="address"></a>
						<div id="addressDetailsHolder" class="address-details" style="display: none;">
							<span id="verifiedOwnerHolder" class="address-detail-chip address-detail-owner" style="display: none;">
								<span id="verifiedOwner"></span>
							</span>
								<span id="addressNameHolder" class="address-detail-chip" style="display: none;">
									<span id="addressName"></span>
								</span>
						</div>
					</div>
				</div>
			</div>
			<div class="row w-100 div-cell-dark border-top-flat p-2 p-lg-3">
				<div class="col-md p-0" id="addressSummaryMain">
					<div id="addressSummaryContent">
							<div class="row w-100">
								<div class="ps-0 pe-0 col-12">
									<div class="address-balance-summary">
										<div class="address-balance-title">Balance</div>
										<div class="address-balance-rows">
											<div id="finalErgBalance" class="address-balance-row"></div>
											<div id="finalAssetsBalance" class="address-balance-row" style="display: none;"></div>
											<div id="finalBalance" class="me-0 me-lg-3 address-balance-row address-balance-total" style="display: none;"></div>
										</div>
									</div>
								</div>
							</div>
							<div style="display: none;" id="1chartHolder">
								<div class="row w-100" id="1chart">
									<div class="col-12">
										<hr class="my-3">
										<h2>Total ERG</h2>
										<br>
										<canvas style="width:100%;" id="chart"></canvas>
									</div>
								</div>
							</div>
							<hr class="my-3 me-0 me-lg-3">
					<div id="addressSectionTabs" class="address-section-tabs" style="display: none;" role="tablist" aria-label="Address assets">
						<button id="ownedNftsTab" class="address-section-tab" style="display: none;" type="button" role="tab" onclick="showAddressSectionTab(event, 'ownedNfts')">
							<span>Owned NFTs</span> <span class="address-section-tab-count">(0)</span>
						</button>
						<button id="issuedAssetsTab" class="address-section-tab" style="display: none;" type="button" role="tab" onclick="showAddressSectionTab(event, 'issuedAssets')">
							<span>Issued Assets</span> <span class="address-section-tab-count">(0)</span>
						</button>
						<button id="unspentBoxesTab" class="address-section-tab" style="display: none;" type="button" role="tab" onclick="showAddressSectionTab(event, 'unspentBoxes')">
							<span>Unspent Boxes</span> <span class="address-section-tab-count">(0)</span>
						</button>
					</div>
					<div class="row w-100">
						<div id="nftsHolder" class="ps-0 pe-0 row w-100 address-section-panel" style="display: none;">
							<div class="col-12 p-0">
								<span id="nftsTitle" class="address-section-title-anchor"><strong>Owned NFTs</strong></span>
								<div id="nftsShowAll" style="display: none;">
									<div id="ownedNftTypeTabs" class="address-asset-type-tabs" style="display: none;" role="tablist" aria-label="Owned NFT types">
										<button id="ownedNftImagesTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'owned', 'image')">
											Images <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="ownedNftAudioTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'owned', 'audio')">
											Audio <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="ownedNftVideoTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'owned', 'video')">
											Video <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="ownedNftArtCollectionTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'owned', 'artCollection')">
											Art <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="ownedNftFileTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'owned', 'fileAttachment')">
											Files <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="ownedNftMembershipTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'owned', 'membershipToken')">
											Membership <span class="address-asset-type-tab-count">(0)</span>
										</button>
									</div>
									<div id="nftImagesHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Image</h5>
										<div class="row w-100 p-0">
											<div id="nftImagesContentHolder" class="col p-0"></div>
										</div>
									</div>
									<div id="nftAudioHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Audio</h5>
										<div class="row w-100 p-0">
											<div id="nftAudioContentHolder" class="col p-0"></div>
										</div>
									</div>
									<div id="nftVideoHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Video</h5>
										<div class="row w-100 p-0">
											<div id="nftVideoContentHolder" class="col p-0"></div>
										</div>
									</div>
									<div id="nftArtCollectionHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Art collection</h5>
										<div class="row w-100 p-0">
											<div id="nftArtCollectionContentHolder" class="col p-0"></div>
										</div>
									</div>
									<div id="nftFileHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">File attachment</h5>
										<div class="row w-100 p-0">
											<div id="nftFileContentHolder" class="col p-0"></div>
										</div>
									</div>
									<div id="nftMembershipHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Membership</h5>
										<div class="row w-100 p-0">
											<div id="nftMembershipContentHolder" class="col p-0"></div>
										</div>
									</div>
								</div>
							</div>
						</div>
						<div id="issuedNftsHolder" class="ps-0 pe-0 row w-100 address-section-panel" style="display: none;">
							<div class="col-12 p-0">
							<span id="issuedNftsTitle" class="address-section-title-anchor"><strong>Issued assets</strong></span>
								<div id="nftsShowIssued" style="display: none;">
									<div id="issuedAssetTypeTabs" class="address-asset-type-tabs" style="display: none;" role="tablist" aria-label="Issued asset types">
										<button id="issuedAssetTokensTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'issued', 'token')">
											Tokens <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="issuedAssetImagesTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'issued', 'image')">
											Images <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="issuedAssetAudioTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'issued', 'audio')">
											Audio <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="issuedAssetVideoTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'issued', 'video')">
											Video <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="issuedAssetArtCollectionTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'issued', 'artCollection')">
											Art <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="issuedAssetFileTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'issued', 'fileAttachment')">
											Files <span class="address-asset-type-tab-count">(0)</span>
										</button>
										<button id="issuedAssetMembershipTab" class="address-asset-type-tab" style="display: none;" type="button" role="tab" onclick="showAddressAssetTypeTab(event, 'issued', 'membershipToken')">
											Membership <span class="address-asset-type-tab-count">(0)</span>
										</button>
									</div>
									<div id="issuedTokenHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Token</h5>
										<div class="row w-100 p-0">
											<div id="issuedTokenContentHolder" class="col p-2"></div>
										</div>
									</div>
									<div id="issuedNftImagesHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Image</h5>
										<div class="row w-100 p-0">
											<div id="issuedNftImagesContentHolder" class="col p-0"></div>
										</div>
									</div>
									<div id="issuedNftAudioHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Audio</h5>
										<div class="row w-100 p-0">
											<div id="issuedNftAudioContentHolder" class="col p-0"></div>
										</div>
									</div>
									<div id="issuedNftVideoHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Video</h5>
										<div class="row w-100 p-0">
											<div id="issuedNftVideoContentHolder" class="col p-0"></div>
										</div>
									</div>
									<div id="issuedNftArtCollectionHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Art collection</h5>
										<div class="row w-100 p-0">
											<div id="issuedNftArtCollectionContentHolder" class="col p-0"></div>
										</div>
									</div>
									<div id="issuedNftFileHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">File attachment</h5>
										<div class="row w-100 p-0">
											<div id="issuedNftFileContentHolder" class="col p-0"></div>
										</div>
									</div>
									<div id="issuedNftMembershipHolder" class="row w-100 p-0" style="display: none;">
										<h5 class="address-nft-type-heading">Membership</h5>
										<div class="row w-100 p-0">
											<div id="issuedNftMembershipContentHolder" class="col p-0"></div>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>	
					
					<div id="unspentBoxesSection" class="row w-100 ps-0 pe-0 address-section-panel" style="display: none;">
						<span id="unspentBoxesHeading" class="address-section-title-anchor"><strong>Unspent Boxes</strong></span>
						<div class="row g-0 p-0 pe-lg-3" id="unspentBoxesHolder">
					
						</div>
						<nav id="unspentBoxesPagination" class="mt-2" style="display: none;" aria-label="Unspent boxes page navigation">
							<ul class="pagination pagination-sm justify-content-center mb-0">
								<li class="page-item unspentFirstPageHolder">
									<a class="page-link unspentFirstPage" href="#" aria-label="First unspent boxes page">
										<span aria-hidden="true">&laquo;</span>
									</a>
								</li>
								<li class="page-item unspentPreviousPageHolder">
									<a class="page-link unspentPreviousPage" href="#" aria-label="Previous unspent boxes page">
										<span aria-hidden="true">&lsaquo;</span>
									</a>
								</li>
								<li class="page-item disabled"><span class="page-link" id="unspentBoxesPageNum">1 of 1</span></li>
								<li class="page-item unspentNextPageHolder">
									<a class="page-link unspentNextPage" href="#" aria-label="Next unspent boxes page">
										<span aria-hidden="true">&rsaquo;</span>
									</a>
								</li>
								<li class="page-item unspentLastPageHolder">
									<a class="page-link unspentLastPage" href="#" aria-label="Last unspent boxes page">
										<span aria-hidden="true">&raquo;</span>
									</a>
								</li>
							</ul>
						</nav>
					</div>
					</div>
				</div>
				<div class="ps-0 pe-0 ps-lg-3 pe-lg-3 col-xl-6 col-lg-6 col-md-12 border-lg-start" id="tokensHolder" style="display:none">
					<hr class="my-3 d-lg-none">
					<div class="address-token-groups">
						<div class="address-token-group" style="display: none;" id="financialAssetsHolder">
							<h4><strong id="financialAssetsTitle">Financial assets</strong></h4>
							<div class="tokensContainer" id="financialTokens"></div>
						</div>
						<div class="address-token-group" style="display: none;" id="otherTokensHolder">
							<h4><strong id="otherTokensTitle">Tokens</strong></h4>
							<div class="tokensContainer" id="otherTokens"></div>
						</div>
					</div>
				</div>
			  </div>
		  </div>

		  <div id="txView" class="row w-100 g-0">

			{% include "partials/pagination.njk" %}

			<table class="table table-dark table-striped table-mobile address-tx-table">
				<thead>
					<tr>
						<th scope="col">Tx</th>
						<th scope="col" style="min-width: 180px">Time</th>
						<th scope="col">Block</th>
						<th style="min-width:98px" scope="col">Type</th>
						<th style="min-width:200px" scope="col">From</th>
						<th style="min-width:200px" scope="col">To</th>
						<th scope="col">Status</th>
						<th scope="col" style="min-width: 105px">Fee</th>
						<th scope="col" >Value</th>
					</tr>
				</thead>

				<tbody id="transactionsTableBody">
				</tbody>
			</table>

			{% include "partials/pagination.njk" %}
		</div>

	  	{% include "partials/error-message.njk" %}
		
		{% include "partials/loading.njk" %}
	</div>

	<div id="qrCodeBack">
		<div id="qrCodeHolder">	
			<div id="qrcode"></div>
		</div>
	</div>
{% endblock %}

{% block scripts %}	
	<script src="./scripts/common/prices.js?v=41"></script>
	<script src="./scripts/common/pagination.js?v=41"></script>
	<script src="./scripts/common/nft.js?v=41"></script>
	<script type="module" src="./scripts/addresses/index.js?v=54"></script>
	<script src="./scripts/3rd-party/qrcode.min.js?v=41"></script>
{% endblock %}
